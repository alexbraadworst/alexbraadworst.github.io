---
layout: base.njk
title: blog
description: blog post index
og_description: blog post index
eleventyExcludeFromCollections: true
---
{% block head %}
    <link rel="stylesheet" href="/css/blogstyle.css">
{% endblock %}

<div class="main">
    <div class="pure-g hero">
        <div class="blog-content">
        <div class="pure-u-1" style="text-align: center; margin-bottom: 2rem; font-family: 'Hack', 'Courier New', Courier, monospace; display: flex; flex-direction: column; align-items: center; gap: 0.5rem;">
            <h1 style="margin: 0;">posts</h1>
            <a href="/feed.xml" title="Subscribe to RSS Feed" aria-label="RSS Feed" class="feed-icon-link" style="display: inline-flex; align-items: center; color: #f26522;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 11a9 9 0 0 1 9 9"></path>
                    <path d="M4 4a16 16 0 0 1 16 16"></path>
                    <circle cx="5" cy="19" r="1"></circle>
                </svg>
            </a>
        </div>

        <div class="blog-grid post-body">
        {% for post in collections.posts | reverse %}
            <div class="blog-card">
                <h3 class="blog-card-title">
                    <a href="{{ post.url }}" class="stretched-link">{{ post.data.title }}</a>
                </h3>
                
                <div class="blog-card-meta" style="font-size: 0.9rem; opacity: 0.8; margin-bottom: 0.5rem;">
                    <time class="blog-card-date">
                        {{ post.date | readableDate }}
                    </time>
                    <span class="meta-divider">·</span>
                    <span class="blog-card-date">
                        {{ post.content | readingTime }}
                    </span>
                </div>
                
                <p class="blog-card-preview">
                    {{ post.content | striptags | truncate(250) | safe }}
                </p>
                
                <span class="blog-card-link" aria-hidden="true">read →</span>
            </div>
        {% endfor %}
        </div>
    </div>
</div>