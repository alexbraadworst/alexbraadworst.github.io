    <title>{{title or "harakiri.moe"}}</title>
    <meta name="description" content="juniper's website">
    <meta name="author" content="jz">

    <meta property="og:type" content="website">
    <meta property="og:title" content="blog post">
    <meta property="og:description" content="read it idk">
    <meta property="og:url" content="https://harakiri.moe">
